{
  "id": "test",
  "type": "test",
  "effort_size": "small",
  "complexity": {
    "business_complexity": "L1_standardized",
    "context_maturity": "C1_complete"
  },
  "time_budget_minutes": 25,
  "max_human_interventions": 2,
  "max_cost_usd": 1.5,
  "target": {
    "repo": "replace-with-public-git-url-or-local-path-for-benchmarks-local",
    "base_ref": "replace-with-full-commit-sha",
    "solution_ref": "optional-reference-solution-sha",
    "language": "replace-with-language",
    "package_manager": "replace-with-package-manager",
    "setup_commands": [],
    "test_commands": [
      "./tests.sh"
    ],
    "working_directory": "."
  },
  "required_tests": [
    "./tests.sh"
  ],
  "hidden_checks": [
    "Tests fail before the production fix or target behavior exists.",
    "Assertions encode behavior, not implementation trivia.",
    "Tests are stable and not over-mocked."
  ],
  "scope": {
    "allowed_paths": [
      "replace-with-target-path/**"
    ]
  },
  "scoring_weights": {
    "correctness": 35,
    "regression_safety": 15,
    "maintainability": 15,
    "test_quality": 10,
    "security": 10,
    "process_compliance": 5,
    "efficiency": 10
  },
  "context_sources": [
    {
      "type": "knowledge",
      "path_globs": [
        "docs/contexts/**"
      ]
    },
    {
      "type": "component_doc",
      "path_globs": [
        "docs/components/**"
      ]
    },
    {
      "type": "project_doc",
      "path_globs": [
        "README.md",
        "README.zh-CN.md",
        "AGENTS.md",
        "docs/**/*.md"
      ]
    },
    {
      "type": "spec",
      "path_globs": [
        "task.md",
        "task.zh-CN.md",
        "specs/**"
      ]
    },
    {
      "type": "skill",
      "path_globs": [
        ".codex/skills/**",
        ".claude/agents/**"
      ]
    }
  ]
}
