{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Coding Evaluation Run",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "workflow_id",
    "task_id",
    "duration_minutes",
    "human_interventions",
    "tests",
    "diff"
  ],
  "properties": {
    "workflow_id": {
      "type": "string",
      "pattern": "^(?!.*\\.\\.)[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "task_id": { "type": "string" },
    "target": {
      "type": "object",
      "properties": {
        "repo": { "type": "string" },
        "base_ref": { "type": "string" },
        "worktree": { "type": "string" },
        "language": { "type": "string" },
        "package_manager": { "type": "string" },
        "working_directory": { "type": "string" }
      }
    },
    "model": { "type": ["string", "null"] },
    "models_used": {
      "type": "array",
      "items": { "type": "string" }
    },
    "duration_minutes": { "type": "number", "minimum": 0 },
    "human_interventions": { "type": "integer", "minimum": 0 },
    "permission_requests": { "type": "integer", "minimum": 0 },
    "cost_usd": { "type": ["number", "null"], "minimum": 0 },
    "tests": {
      "type": "object",
      "required": ["required_passed", "hidden_passed"],
      "properties": {
        "required_passed": { "type": "boolean" },
        "hidden_passed": { "type": ["boolean", "null"] }
      }
    },
    "diff": {
      "type": "object",
      "required": ["files_changed", "unrelated_files_changed"],
      "properties": {
        "files_changed": { "type": "integer", "minimum": 0 },
        "unrelated_files_changed": { "type": ["integer", "null"], "minimum": 0 },
        "unrelated_files": {
          "type": ["array", "null"],
          "items": { "type": "string" }
        },
        "scope_check": { "type": "string" }
      }
    },
    "process_evidence": {
      "type": "object",
      "properties": {
        "project_instructions_read": { "type": "boolean" },
        "relevant_docs_read": {
          "type": "array",
          "items": { "type": "string" }
        },
        "knowledge_sources_used": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tools_used": {
          "type": "array",
          "items": { "type": "string" }
        },
        "plan_followed": { "type": "boolean" },
        "self_review_performed": { "type": "boolean" }
      }
    },
    "adoption": {
      "type": "object",
      "properties": {
        "ai_generated_lines": { "type": ["integer", "null"], "minimum": 0 },
        "accepted_lines": { "type": ["integer", "null"], "minimum": 0 },
        "adoption_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      }
    },
    "context_metrics": {
      "type": "object",
      "properties": {
        "call_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "hit_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "adoption_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      }
    },
    "event_collection": {
      "type": "object",
      "properties": {
        "events_path": { "type": "string" },
        "event_count": { "type": "integer", "minimum": 0 },
        "sources": {
          "type": "array",
          "items": { "type": "string" }
        },
        "summarized_at": { "type": "string" }
      }
    }
  }
}
